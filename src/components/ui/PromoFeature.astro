---
interface Props {
  name: string;
  description: string;
  badge?: string;
  image: {
    src: string;
    alt: string;
  };
}

const { name, description, badge, image } = Astro.props;
---

<article class="promo-feature">
  <div class="promo-feature__media">
    <img
      class="promo-feature__image"
      src={image.src}
      alt={image.alt}
      width="640"
      height="480"
      loading="lazy"
      decoding="async"
    />
  </div>

  <div class="promo-feature__body">
    {badge && <span class="promo-feature__badge">{badge}</span>}
    <h3 class="promo-feature__title">{name}</h3>
    <p class="promo-feature__description">{description}</p>
  </div>
</article>

<style>
  .promo-feature {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--space-lg);
    background-color: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
  }

  .promo-feature__media {
    overflow: hidden;
    border-radius: var(--radius-md);
    aspect-ratio: 4 / 3;
  }

  .promo-feature__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .promo-feature__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding-top: var(--space-lg);
  }

  .promo-feature__badge {
    align-self: flex-start;
    padding: 0.375rem 0.75rem;
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: var(--tracking-label);
    color: var(--color-on-matcha);
    background-color: var(--color-matcha);
    border-radius: var(--radius-pill);
  }

  .promo-feature__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-title);
    font-weight: 600;
    line-height: 1.25;
    color: var(--color-primary-deep);
  }

  .promo-feature__description {
    margin: 0;
    font-size: 0.9375rem;
    line-height: var(--leading-body);
    color: var(--color-ink);
    text-wrap: pretty;
  }
</style>
