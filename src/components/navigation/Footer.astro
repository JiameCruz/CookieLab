---
import { contact, footer, site } from '@/config/site';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__top">
      <div class="footer__brand">
        <a href="/" class="footer__logo" aria-label={`${site.name} — inicio`}>
          {site.name}
        </a>
        <p class="footer__tagline">{site.tagline}</p>
        <address class="footer__address">
          {contact.address.line}
        </address>
      </div>

      <nav class="footer__nav" aria-label="Enlaces del pie de página">
        {
          footer.groups.map((group) => (
            <div class="footer__group">
              <h2 class="footer__group-title">{group.title}</h2>
              <ul class="footer__links" role="list">
                {group.links.map((link) => (
                  <li>
                    <a
                      class="footer__link"
                      href={link.href}
                      {...(link.external
                        ? { target: '_blank', rel: 'noopener noreferrer' }
                        : {})}
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </nav>
    </div>

    <div class="footer__bottom">
      <ul class="footer__social" role="list" aria-label="Redes sociales">
        {
          footer.social.map((item) => (
            <li>
              <a
                class="footer__social-link"
                href={item.href}
                {...(item.id !== 'phone'
                  ? { target: '_blank', rel: 'noopener noreferrer' }
                  : {})}
                aria-label={item.label}
              >
                {item.id === 'instagram' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <rect
                      x="3"
                      y="3"
                      width="18"
                      height="18"
                      rx="5"
                      stroke="currentColor"
                      stroke-width="1.75"></rect>
                    <circle cx="12" cy="12" r="3.75" stroke="currentColor" stroke-width="1.75"
                    ></circle>
                    <circle cx="17.2" cy="6.8" r="0.9" fill="currentColor"></circle>
                  </svg>
                )}
                {item.id === 'whatsapp' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path
                      d="M12 2a10 10 0 0 0-8.66 15.03L2 22l5.17-1.35A10 10 0 1 0 12 2Z"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linejoin="round"></path>
                    <path
                      d="M8.5 9.5c.3-.7.5-.7.9-.7h.5c.1 0 .3 0 .4.3l.6 1.4c.1.2 0 .4-.1.6l-.3.4c-.1.2-.1.3 0 .5.4.7 1.1 1.4 1.8 1.8.2.1.3.1.5 0l.4-.3c.2-.1.4-.2.6-.1l1.4.6c.3.1.3.3.3.4v.5c0 .4-.1.6-.7.9-1 .5-2.1-.2-3.3-1.3-1.2-1.2-1.8-2.3-1.3-3.3Z"
                      fill="currentColor"></path>
                  </svg>
                )}
                {item.id === 'phone' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path
                      d="M6.5 3h2.1l1.2 4.8-1.6 1.1a11.5 11.5 0 0 0 5.3 5.3l1.1-1.6 4.8 1.2v2.1c0 .8-.6 1.5-1.4 1.6-8.2.9-14.8-6.7-13.9-14.9.1-.8.8-1.4 1.6-1.4Z"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linejoin="round"></path>
                  </svg>
                )}
                <span class="footer__social-label">{item.label}</span>
              </a>
            </li>
          ))
        }
      </ul>

      <p class="footer__copy">
        <small>© {year} {site.name}. Torreón, Coahuila.</small>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding-block: clamp(var(--space-2xl), 6vw, var(--space-3xl));
    background-color: var(--color-primary-deep);
    color: oklch(0.92 0.01 155);
  }

  .footer__top {
    display: grid;
    gap: clamp(var(--space-xl), 5vw, var(--space-2xl));
  }

  .footer__brand {
    max-width: 22rem;
  }

  .footer__logo {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 600;
    letter-spacing: var(--tracking-display);
    color: var(--color-on-primary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-quart);
  }

  .footer__logo:hover {
    color: var(--color-brand-pink);
  }

  .footer__tagline {
    margin: var(--space-sm) 0 0;
    font-size: 0.9375rem;
    line-height: var(--leading-body);
    color: oklch(0.78 0.02 155);
    text-wrap: pretty;
  }

  .footer__address {
    margin: var(--space-md) 0 0;
    font-style: normal;
    font-size: 0.875rem;
    line-height: 1.5;
    color: oklch(0.68 0.02 155);
  }

  .footer__nav {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 9rem), 1fr));
    gap: clamp(var(--space-lg), 4vw, var(--space-xl));
  }

  .footer__group-title {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: oklch(0.72 0.03 155);
  }

  .footer__links {
    margin: var(--space-sm) 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--space-sm);
  }

  .footer__link {
    display: inline-block;
    font-size: 0.9375rem;
    font-weight: 600;
    color: oklch(0.9 0.01 155);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-quart);
  }

  .footer__link:hover {
    color: var(--color-brand-pink);
  }

  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-top: clamp(var(--space-xl), 5vw, var(--space-2xl));
    padding-top: clamp(var(--space-lg), 4vw, var(--space-xl));
    border-top: 1px solid oklch(1 0 0 / 0.1);
  }

  .footer__social {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .footer__social-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.625rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: oklch(0.9 0.01 155);
    text-decoration: none;
    background-color: oklch(1 0 0 / 0.08);
    border-radius: var(--radius-pill);
    transition:
      background-color var(--duration-fast) var(--ease-out-quart),
      color var(--duration-fast) var(--ease-out-quart);
  }

  .footer__social-link:hover {
    color: var(--color-on-primary);
    background-color: oklch(1 0 0 / 0.14);
  }

  .footer__social-label {
    line-height: 1;
  }

  .footer__copy {
    margin: 0;
    font-size: 0.8125rem;
    color: oklch(0.62 0.02 155);
  }

  @media (min-width: 768px) {
    .footer__top {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.6fr);
      align-items: start;
    }

    .footer__bottom {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
</style>
