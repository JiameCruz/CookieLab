---
import { contact } from '@/config/site';
import {
  getMapsDirectionsUrl,
  getMapsEmbedUrl,
  getMapsSearchUrl,
} from '@/lib/maps';

const { id, headline, subheadline, address, phone, instagram, hours } = contact;
const mapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY;
const embedUrl = getMapsEmbedUrl(address.line, mapsApiKey);
const directionsUrl = getMapsDirectionsUrl(address.line);
const searchUrl = getMapsSearchUrl(address.line);
---

<section class="contact" id={id} aria-labelledby="contact-heading">
  <div class="contact__inner container">
    <header class="contact__header">
      <h2 id="contact-heading" class="headline">{headline}</h2>
      <p class="section-lead">{subheadline}</p>
    </header>

    <div class="contact__layout">
      <div class="contact__details">
        <dl class="contact__list">
          <div class="contact__item">
            <dt class="contact__term">
              <span class="contact__icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M12 21s7-4.5 7-11a7 7 0 1 0-14 0c0 6.5 7 11 7 11Z"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linejoin="round"></path>
                  <circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.75"
                  ></circle>
                </svg>
              </span>
              Dirección
            </dt>
            <dd class="contact__value">
              <a class="contact__link" href={searchUrl} target="_blank" rel="noopener noreferrer">
                {address.line}
              </a>
            </dd>
          </div>

          <div class="contact__item">
            <dt class="contact__term">
              <span class="contact__icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M6.5 3h2.1l1.2 4.8-1.6 1.1a11.5 11.5 0 0 0 5.3 5.3l1.1-1.6 4.8 1.2v2.1c0 .8-.6 1.5-1.4 1.6-8.2.9-14.8-6.7-13.9-14.9.1-.8.8-1.4 1.6-1.4Z"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linejoin="round"></path>
                </svg>
              </span>
              Teléfono
            </dt>
            <dd class="contact__value">
              <a class="contact__link" href={phone.href}>{phone.display}</a>
            </dd>
          </div>

          <div class="contact__item">
            <dt class="contact__term">
              <span class="contact__icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <rect
                    x="3"
                    y="3"
                    width="18"
                    height="18"
                    rx="5"
                    stroke="currentColor"
                    stroke-width="1.75"></rect>
                  <circle cx="12" cy="12" r="3.75" stroke="currentColor" stroke-width="1.75"
                  ></circle>
                  <circle cx="17.2" cy="6.8" r="0.9" fill="currentColor"></circle>
                </svg>
              </span>
              Instagram
            </dt>
            <dd class="contact__value">
              <a
                class="contact__link"
                href={instagram.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                {instagram.label}
              </a>
            </dd>
          </div>

          <div class="contact__item contact__item--hours">
            <dt class="contact__term">
              <span class="contact__icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="8.25" stroke="currentColor" stroke-width="1.75"
                  ></circle>
                  <path
                    d="M12 7.5V12l3 2.25"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </span>
              Horario
            </dt>
            <dd class="contact__value">
              <ul class="contact__hours" role="list">
                {
                  hours.map((entry) => (
                    <li class="contact__hours-row">
                      <span class="contact__hours-days">{entry.days}</span>
                      <span class="contact__hours-time">{entry.time}</span>
                    </li>
                  ))
                }
              </ul>
            </dd>
          </div>
        </dl>

        <a class="contact__directions" href={directionsUrl} target="_blank" rel="noopener noreferrer">
          Cómo llegar
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <figure class="contact__map-wrap">
        <iframe
          class="contact__map"
          src={embedUrl}
          title="Ubicación de The Cookie Lab en Google Maps — Blvd. Independencia 295, Torreón"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen></iframe>
      </figure>
    </div>
  </div>
</section>

<style>
  .contact {
    padding-block: var(--space-3xl);
    background-color: var(--color-surface);
  }

  .contact__header {
    margin-bottom: clamp(var(--space-xl), 5vw, var(--space-2xl));
    max-width: 42rem;
  }

  .contact__layout {
    display: grid;
    gap: clamp(var(--space-xl), 5vw, var(--space-2xl));
    align-items: start;
  }

  .contact__list {
    margin: 0;
    display: grid;
    gap: var(--space-lg);
  }

  .contact__item {
    margin: 0;
    display: grid;
    gap: var(--space-sm);
  }

  .contact__term {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .contact__icon {
    display: inline-flex;
    flex-shrink: 0;
    color: var(--color-matcha);
  }

  .contact__value {
    margin: 0;
    padding-inline-start: calc(20px + var(--space-sm));
    font-size: clamp(1rem, 2vw, 1.0625rem);
    line-height: var(--leading-body);
    color: var(--color-ink);
  }

  .contact__link {
    color: var(--color-ink);
    text-decoration: none;
    text-underline-offset: 0.15em;
    transition: color var(--duration-fast) var(--ease-out-quart);
  }

  .contact__link:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .contact__hours {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--space-xs);
  }

  .contact__hours-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm) var(--space-md);
    justify-content: space-between;
    max-width: 22rem;
  }

  .contact__hours-days {
    font-weight: 600;
    color: var(--color-ink);
  }

  .contact__hours-time {
    color: var(--color-muted);
  }

  .contact__directions {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xl);
    padding: 0.75rem 1.25rem;
    font-family: var(--font-body);
    font-size: var(--text-nav);
    font-weight: 600;
    color: var(--color-on-matcha);
    text-decoration: none;
    background-color: var(--color-matcha);
    border-radius: var(--radius-pill);
    transition:
      background-color var(--duration-fast) var(--ease-out-quart),
      transform var(--duration-fast) var(--ease-out-quart);
  }

  .contact__directions:hover {
    background-color: oklch(0.46 0.12 155);
  }

  .contact__directions:active {
    transform: scale(0.98);
  }

  .contact__map-wrap {
    margin: 0;
    min-height: clamp(16rem, 45vw, 24rem);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lift-hover);
    background-color: var(--color-line);
  }

  .contact__map {
    display: block;
    width: 100%;
    height: 100%;
    min-height: inherit;
    border: 0;
  }

  @media (min-width: 768px) {
    .contact__layout {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
      gap: clamp(var(--space-2xl), 6vw, 4rem);
      align-items: stretch;
    }

    .contact__map-wrap {
      min-height: 100%;
    }
  }

  @media (min-width: 1024px) {
    .contact__header {
      max-width: 36rem;
    }
  }
</style>
