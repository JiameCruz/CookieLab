---
import Button from '@/components/ui/Button.astro';
import { hero } from '@/config/site';

const { headline, subheadline, cta, image } = hero;
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__media" aria-hidden="true">
    <img
      class="hero__image"
      src={image.src}
      alt=""
      width="1920"
      height="1280"
      fetchpriority="high"
      decoding="async"
    />
    <div class="hero__scrim"></div>
  </div>

  <div class="hero__content container">
    <div class="hero__copy">
      <h1 id="hero-heading" class="hero__headline headline">
        {headline}
      </h1>
      <p class="hero__subheadline">
        {subheadline}
      </p>
      <div class="hero__actions">
        <Button href={cta.href} label={cta.label} variant="primary" />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: grid;
    min-height: clamp(30rem, 88vh, 46rem);
    overflow: hidden;
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: var(--z-hero-overlay);
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    transform: scale(1.03);
    animation: hero-image-in var(--duration-reveal) var(--ease-out-quart) both;
  }

  .hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      oklch(0.95 0.03 350 / 0.96) 0%,
      oklch(0.95 0.03 350 / 0.88) 32%,
      oklch(0.95 0.025 350 / 0.45) 58%,
      oklch(0.95 0.02 350 / 0.08) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: var(--z-hero-content);
    display: flex;
    align-items: flex-end;
    padding-block: clamp(var(--space-2xl), 10vh, var(--space-3xl));
  }

  .hero__copy {
    max-width: min(36rem, 90%);
    animation: hero-copy-in var(--duration-reveal) var(--ease-out-quart) 80ms both;
  }

  .hero__headline {
    margin: 0;
    max-width: 14ch;
    font-size: var(--text-display);
    line-height: var(--leading-display);
  }

  .hero__subheadline {
    margin: var(--space-lg) 0 0;
    max-width: 34ch;
    font-family: var(--font-body);
    font-size: clamp(1rem, 2.2vw, 1.125rem);
    font-weight: 400;
    line-height: var(--leading-body);
    color: var(--color-ink);
    text-wrap: pretty;
  }

  .hero__actions {
    margin-top: var(--space-xl);
  }

  @keyframes hero-image-in {
    from {
      opacity: 0.9;
      transform: scale(1.07);
    }
    to {
      opacity: 1;
      transform: scale(1.03);
    }
  }

  @keyframes hero-copy-in {
    from {
      opacity: 0;
      transform: translateY(1rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__image,
    .hero__copy {
      animation: none;
    }
  }

  @media (max-width: 640px) {
    .hero {
      min-height: clamp(26rem, 80vh, 38rem);
    }

    .hero__content {
      align-items: center;
    }

    .hero__headline {
      max-width: none;
      font-size: clamp(2rem, 8vw, 3rem);
    }

    .hero__scrim {
      background: linear-gradient(
        180deg,
        oklch(0.95 0.03 350 / 0.94) 0%,
        oklch(0.95 0.03 350 / 0.82) 50%,
        oklch(0.95 0.02 350 / 0.25) 100%
      );
    }

    .hero__subheadline {
      max-width: none;
    }
  }
</style>
