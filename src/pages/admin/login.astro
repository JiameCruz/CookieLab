---
import AdminLayout from '@/layouts/AdminLayout.astro';

export const prerender = false;

const redirect = Astro.url.searchParams.get('redirect') ?? '/admin';
const safeRedirect = redirect.startsWith('/admin') ? redirect : '/admin';
---

<AdminLayout title="Entrar" showChrome={false}>
  <div class="login">
    <div class="login__panel">
      <div class="login__brand">CookingLab</div>
      <p class="login__lead">Panel del mostrador</p>

      <form class="login__form" id="login-form" novalidate data-redirect={safeRedirect}>
        <div class="form-error" id="login-error" role="alert" aria-live="polite"></div>

        <div class="field">
          <label class="field__label" for="email">Correo</label>
          <input
            class="field__input"
            type="email"
            id="email"
            name="email"
            autocomplete="username"
            inputmode="email"
            placeholder="admin@gmail.com"
            required
          />
        </div>

        <div class="field">
          <label class="field__label" for="password">Contraseña</label>
          <div class="field__password">
            <input
              class="field__input"
              type="password"
              id="password"
              name="password"
              autocomplete="current-password"
              placeholder="Tu contraseña"
              required
            />
            <button type="button" class="field__toggle" data-toggle-password aria-label="Mostrar contraseña">
              Ver
            </button>
          </div>
        </div>

        <button type="submit" class="abtn abtn--primary login__submit" id="login-submit">
          Entrar
        </button>
      </form>
    </div>
  </div>

  <div class="toast-stack" id="toast-stack" aria-live="polite" aria-atomic="true"></div>
</AdminLayout>

<style>
  .login {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100dvh - var(--space-xl) - var(--space-3xl));
    padding: var(--space-lg);
  }

  .login__panel {
    position: relative;
    width: min(26rem, 100%);
    padding: clamp(1.75rem, 5vw, 2.5rem);
    background-color: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
  }

  /* Acento de marca contenido (<=12% del panel) */
  .login__panel::before {
    content: '';
    position: absolute;
    top: -10px;
    left: clamp(1.75rem, 5vw, 2.5rem);
    width: 3.5rem;
    height: 3.5rem;
    border-radius: var(--radius-pill);
    background-color: var(--color-brand-pink-soft);
    z-index: 0;
  }

  .login__brand {
    position: relative;
    z-index: 1;
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: var(--tracking-display);
    color: var(--color-primary-deep);
  }

  .login__lead {
    position: relative;
    z-index: 1;
    margin: 0.25rem 0 var(--space-lg);
    color: var(--color-muted);
  }

  .login__submit {
    width: 100%;
    margin-top: var(--space-xs);
  }
</style>

<script>
  const form = document.getElementById('login-form') as HTMLFormElement;
  const submit = document.getElementById('login-submit') as HTMLButtonElement;
  const errorBox = document.getElementById('login-error') as HTMLElement;
  const toggle = document.querySelector('[data-toggle-password]') as HTMLButtonElement;
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const redirectTo = form?.dataset.redirect || '/admin';

  toggle?.addEventListener('click', () => {
    const isText = passwordInput.type === 'text';
    passwordInput.type = isText ? 'password' : 'text';
    toggle.textContent = isText ? 'Ver' : 'Ocultar';
    toggle.setAttribute('aria-label', isText ? 'Mostrar contraseña' : 'Ocultar contraseña');
  });

  const showError = (message: string) => {
    errorBox.textContent = message;
    errorBox.dataset.show = 'true';
  };

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    errorBox.dataset.show = 'false';

    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const password = passwordInput.value;

    if (!email || !password) {
      showError('Ingresa tu correo y contraseña.');
      return;
    }

    submit.dataset.loading = 'true';
    submit.disabled = true;

    try {
      const res = await fetch('/api/session', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });
      const data = await res.json().catch(() => ({}));

      if (!res.ok) {
        showError(data.error ?? 'No se pudo iniciar sesión.');
        submit.dataset.loading = 'false';
        submit.disabled = false;
        return;
      }

      window.location.href = redirectTo;
    } catch {
      showError('Error de red. Inténtalo de nuevo.');
      submit.dataset.loading = 'false';
      submit.disabled = false;
    }
  });
</script>
