# Neon Postgres — connection string del branch (Neon Console o `neonctl connection-string`)
DATABASE_URL=

# Neon Auth (Better Auth gestionado) — Project > Branch > Auth, o `provision_neon_auth`
PUBLIC_NEON_AUTH_URL=
NEON_AUTH_JWKS_URL=

# Secreto para firmar/identificar la cookie de sesión del panel admin (string aleatorio)
SESSION_COOKIE_SECRET=

# Google Maps Embed API — https://console.cloud.google.com/google/maps-apis
# Habilita "Maps Embed API" y crea una clave restringida por dominio.
PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Vercel (Project Settings > Environment Variables) ---
# Copia las variables anteriores en Production y Preview.
# En Neon Auth, añade como orígenes permitidos:
#   https://cookinglab.mx
#   https://*.vercel.app
